{
  "name": "galley",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "bin": {
    "galley": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node scripts/build-ui.mjs --watch & tsx src/cli.ts",
    "build": "tsc && tsc -p tsconfig.ui.json && node scripts/build-ui.mjs && cp src/ui/index.html dist/index.html",
    "start": "node dist/cli.js",
    "check": "tsc --noEmit && tsc -p tsconfig.ui.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "@types/alpinejs__persist": "^3.13.4",
    "@types/node": "latest",
    "esbuild": "^0.28.0",
    "tsx": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@alpinejs/persist": "^3.15.12",
    "@comark/html": "^0.3.1",
    "@pierre/diffs": "1.2.4",
    "alpinejs": "^3.15.12",
    "dompurify": "^3.4.8",
    "shiki": "^4.2.0"
  }
}
